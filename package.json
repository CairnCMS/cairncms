{
	"name": "cairncms-monorepo",
	"private": true,
	"scripts": {
		"build": "pnpm --recursive --filter '!docs' run build",
		"format": "prettier --write \"**/*.{md,y?(a)ml,json}\"",
		"lint": "eslint .",
		"test": "pnpm --recursive --filter '!tests-blackbox' test",
		"test:blackbox": "pnpm --filter cairncms deploy --prod dist && pnpm --filter tests-blackbox test"
	},
	"devDependencies": {
		"@typescript-eslint/eslint-plugin": "5.59.0",
		"@typescript-eslint/parser": "5.59.0",
		"eslint": "8.38.0",
		"eslint-config-prettier": "8.8.0",
		"eslint-plugin-jest": "27.2.1",
		"eslint-plugin-prettier": "4.2.1",
		"eslint-plugin-vue": "9.11.0",
		"prettier": "2.8.7"
	},
	"packageManager": "pnpm@8.3.1",
	"engines": {
		"node": ">=18.0.0",
		"pnpm": ">=8.1.0"
	},
	"pnpm": {
		"overrides": {
			"form-data@<2.5.4": "2.5.4",
			"@babel/traverse@<7.23.2": "7.23.2",
			"body-parser@<1.20.3": "1.20.3",
			"ws@>=8.0.0 <8.17.1": "8.17.1",
			"flatted": "3.4.2",
			"tar": "7.5.11",
			"socket.io-parser": "4.2.6",
			"immutable": "4.3.8",
			"lodash": "4.18.1",
			"minimatch@3": "3.1.4",
			"underscore": "1.13.8",
			"serialize-javascript@<7.0.5": "7.0.5",
			"semver@>=7.0.0 <7.5.2": "7.5.2",
			"yaml@2": "2.8.3",
			"path-to-regexp@<0.1.13": "0.1.13",
			"jws@<=3.2.2": "3.2.3",
			"jws@4.0.0": "4.0.1",
			"fast-xml-parser": "4.5.5",
			"tmp@0.2.1": "0.2.4"
		}
	}
}
