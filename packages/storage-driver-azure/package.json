{
	"name": "@cairncms/storage-driver-azure",
	"version": "1.0.0-beta.2",
	"type": "module",
	"scripts": {
		"build": "tsc --build",
		"dev": "tsc --watch",
		"test": "vitest --watch=false"
	},
	"description": "Azure file storage abstraction for `@cairncms/storage`",
	"repository": {
		"type": "git",
		"url": "https://github.com/CairnCMS/cairncms.git",
		"directory": "packages/storage-driver-azure"
	},
	"license": "GPL-3.0-only",
	"author": "The CairnCMS Authors",
	"exports": {
		".": "./dist/index.js",
		"./package.json": "./package.json"
	},
	"main": "dist/index.js",
	"files": [
		"dist",
		"!**/*.d.ts?(.map)"
	],
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@azure/storage-blob": "12.14.0",
		"@cairncms/storage": "workspace:*",
		"@cairncms/utils": "workspace:*"
	},
	"devDependencies": {
		"@ngneat/falso": "6.4.0",
		"@vitest/coverage-v8": "1.6.1",
		"typescript": "5.0.4",
		"vitest": "1.6.1"
	}
}
