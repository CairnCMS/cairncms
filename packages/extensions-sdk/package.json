{
	"name": "@cairncms/extensions-sdk",
	"version": "1.0.0-beta.1",
	"description": "A toolkit to develop extensions to extend CairnCMS",
	"homepage": "https://cairncms.dev",
	"type": "module",
	"bugs": {
		"url": "https://github.com/CairnCMS/cairncms/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/CairnCMS/cairncms.git",
		"directory": "packages/extensions-sdk"
	},
	"author": "The CairnCMS Authors",
	"exports": {
		".": "./dist/index.js",
		"./cli": "./dist/cli/index.js",
		"./package.json": "./package.json"
	},
	"main": "dist/index.js",
	"bin": {
		"cairncms-extension": "cli.js"
	},
	"files": [
		"dist",
		"templates",
		"!**/*.test.{js,d.ts}"
	],
	"scripts": {
		"build": "tsc --build",
		"dev": "tsc --watch",
		"test": "vitest --watch=false"
	},
	"dependencies": {
		"@cairncms/composables": "workspace:*",
		"@cairncms/constants": "workspace:*",
		"@cairncms/types": "workspace:*",
		"@cairncms/utils": "workspace:*",
		"@rollup/plugin-commonjs": "24.1.0",
		"@rollup/plugin-json": "6.0.0",
		"@rollup/plugin-node-resolve": "15.0.2",
		"@rollup/plugin-replace": "5.0.2",
		"@rollup/plugin-terser": "0.4.1",
		"@rollup/plugin-virtual": "3.0.1",
		"@vue/compiler-sfc": "3.2.47",
		"chalk": "5.2.0",
		"commander": "10.0.1",
		"esbuild": "0.17.17",
		"execa": "7.1.1",
		"fs-extra": "11.1.1",
		"inquirer": "9.1.5",
		"ora": "6.3.0",
		"rollup": "4.60.1",
		"rollup-plugin-esbuild": "5.0.0",
		"rollup-plugin-styles": "4.0.0",
		"rollup-plugin-vue": "6.0.0"
	},
	"devDependencies": {
		"@types/fs-extra": "11.0.1",
		"@types/inquirer": "9.0.3",
		"@vitest/coverage-v8": "1.6.1",
		"typescript": "5.0.4",
		"vitest": "1.6.1"
	},
	"engines": {
		"node": ">=12.20.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"license": "MIT"
}
