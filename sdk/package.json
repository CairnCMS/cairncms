{
	"name": "@cairncms/sdk",
	"version": "1.0.0-beta.3",
	"description": "CairnCMS JavaScript SDK",
	"homepage": "https://github.com/CairnCMS/cairncms",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/CairnCMS/cairncms.git",
		"directory": "sdk"
	},
	"license": "MIT",
	"author": "The CairnCMS Authors",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./package.json": "./package.json"
	},
	"main": "./dist/index.js",
	"files": [
		"dist",
		"NOTICE"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "NODE_ENV=production tsup",
		"dev": "NODE_ENV=development tsup",
		"test": "vitest --typecheck --watch=false",
		"test:integration": "vitest --config vitest.integration.config.ts --run"
	},
	"devDependencies": {
		"@types/node-fetch": "2.6.11",
		"esbuild-plugin-replace": "1.4.0",
		"knex": "2.4.2",
		"sqlite3": "5.1.6",
		"tsup": "8.2.2",
		"typescript": "5.4.5",
		"vitest": "1.5.3"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
